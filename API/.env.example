# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_NAME=IgniteHub

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=ignitehub
DB_PASSWORD=ignitehub_secret
DB_NAME=ignitehub_db
DB_SYNC=false          # Set to true only during initial dev (auto-migrates schema)
DB_LOGGING=true

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_me_with_a_long_random_string
JWT_EXPIRES_IN=7d

# ─── Google OAuth 2.0 (Calendar integration) ──────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="IgniteHub <no-reply@ignitehub.io>"

# ─── AI Matching ──────────────────────────────────────────────────────────────
# Minimum cosine similarity score to surface a match (0.0 – 1.0)
MATCH_SCORE_THRESHOLD=0.5
